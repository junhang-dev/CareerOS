{
  "name": "careeros",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check": "node ./scripts/validate-structure.mjs",
    "dev:web": "npm run dev --workspace @careeros/web",
    "db:up": "docker compose -f infra/docker/docker-compose.postgres.yml up -d",
    "db:down": "docker compose -f infra/docker/docker-compose.postgres.yml down",
    "db:generate": "npm run generate --workspace @careeros/db",
    "db:push": "npm run push --workspace @careeros/db"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
