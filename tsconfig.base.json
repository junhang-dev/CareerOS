{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@careeros/domain/*": ["packages/domain/src/*"],
      "@careeros/integrations/*": ["packages/integrations/src/*"],
      "@careeros/security/*": ["packages/security/src/*"],
      "@careeros/workers/*": ["packages/workers/src/*"],
      "@careeros/config/*": ["packages/config/*"]
    }
  }
}

